{
  "name": "app-dev-core",
  "version": "0.2.0",
  "private": true,
  "description": "Development control plane: archetypes, generator, schemas, enforcement.",
  "license": "Apache-2.0",
  "author": "Niel Pieterse",
  "homepage": "https://github.com/NielPieterse0/app-dev-core#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/NielPieterse0/app-dev-core.git"
  },
  "keywords": [
    "app-dev-core",
    "archetypes",
    "developer-tooling",
    "generator",
    "governance",
    "typescript"
  ],
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "packageManager": "npm@10.9.0",
  "scripts": {
    "verify": "npm run governance:check && npm run verify-core && npm run test-enforcement && npm run test-generator && npm run test-archetype",
    "release:check": "tsx scripts/release-check.ts",
    "governance:compile": "tsx governance/compile.ts",
    "governance:check": "tsx governance/compile.ts --check",
    "verify-core": "tsx scripts/verify-core.ts",
    "test-enforcement": "vitest run tests/enforcement governance/registry.test.ts",
    "test-generator": "vitest run tests/generate.test.ts",
    "test-archetype": "tsx scripts/test-archetype.ts",
    "generate": "tsx scripts/generate.ts"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.10"
  }
}

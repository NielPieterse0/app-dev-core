# Normalize line endings. Windows dev box, Linux CI — this is the file that stops
# CRLF from becoming a diff-noise and shebang-breaking problem.
* text=auto eol=lf

*.ps1  text eol=crlf
*.bat  text eol=crlf
*.cmd  text eol=crlf

*.png  binary
*.jpg  binary
*.ico  binary
*.woff binary
*.woff2 binary

package-lock.json linguist-generated=true -diff
